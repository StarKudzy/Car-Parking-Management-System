<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="322.0" prefWidth="273.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.example.car_parking_management_system.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <AnchorPane prefHeight="200.0" prefWidth="200.0">
      <children>
         <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" text="Button" />
         <Button layoutX="136.0" layoutY="21.0" mnemonicParsing="false" text="Button" />
         <Button layoutX="76.0" layoutY="100.0" mnemonicParsing="false" text="Button" />
      </children>
   </AnchorPane>

    <Label fx:id="welcomeText" />
    <Button onAction="#onHelloButtonClick" text="Hello!" />
</VBox>
